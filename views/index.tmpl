<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>The Grandmaster Editorial | Play Chess</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" crossorigin="anonymous"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "tertiary-fixed":              "#ece0dc",
            "on-secondary-container":      "#dab36a",
            "error":                       "#ffb4ab",
            "outline-variant":             "#504442",
            "on-error-container":          "#ffdad6",
            "surface-container-high":      "#202c32",
            "primary-container":           "#003508",
            "on-primary":                  "#003909",
            "on-secondary-fixed":          "#261900",
            "surface-container-highest":   "#2a363d",
            "outline":                     "#9c8d8b",
            "secondary-fixed-dim":         "#e9c176",
            "primary":                     "#88d982",
            "on-background":               "#d7e4ec",
            "secondary":                   "#e9c176",
            "surface-container":           "#152127",
            "tertiary":                    "#cfc4c0",
            "on-primary-container":        "#56a555",
            "inverse-primary":             "#1b6d24",
            "surface":                     "#09151a",
            "tertiary-fixed-dim":          "#cfc4c0",
            "tertiary-container":          "#322c29",
            "primary-fixed-dim":           "#88d982",
            "surface-bright":              "#2f3b41",
            "on-tertiary-fixed":           "#201a18",
            "secondary-container":         "#604403",
            "surface-dim":                 "#09151a",
            "background":                  "#09151a",
            "on-secondary-fixed-variant":  "#5d4201",
            "inverse-on-surface":          "#263238",
            "error-container":             "#93000a",
            "surface-container-lowest":    "#041015",
            "on-tertiary-fixed-variant":   "#4c4542",
            "primary-fixed":               "#a3f69c",
            "on-secondary":                "#412d00",
            "on-primary-fixed-variant":    "#005312",
            "on-tertiary-container":       "#9c938f",
            "surface-container-low":       "#111d23",
            "secondary-fixed":             "#ffdea5",
            "surface-tint":                "#88d982",
            "on-surface-variant":          "#d3c3c0",
            "on-error":                    "#690005",
            "inverse-surface":             "#d7e4ec",
            "on-primary-fixed":            "#002204",
            "surface-variant":             "#2a363d",
            "on-surface":                  "#d7e4ec",
            "on-tertiary":                 "#352f2d"
          },
          borderRadius: {
            "DEFAULT": "0.125rem",
            "lg":      "0.25rem",
            "xl":      "0.5rem",
            "full":    "0.75rem"
          },
          fontFamily: {
            "headline": ["Noto Serif", "serif"],
            "body":     ["Inter", "sans-serif"],
            "label":    ["Inter", "sans-serif"]
          }
        },
      },
    }
  </script>
  <link rel="stylesheet" href="/public/assets/indexStyle.css">
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col">

  <!-- Header -->
  <header class="w-full flex justify-between items-center px-6 md:px-12 h-20 bg-surface-container-low/50 backdrop-blur-md border-b border-white/5 z-50">
    <div class="text-xl font-headline italic text-on-surface tracking-widest">
      The Grandmaster Editorial
    </div>
    <div class="flex items-center gap-4 md:gap-6">
      <div class="hidden sm:flex bg-surface-container-highest/40 p-2 rounded-lg items-center gap-2 border border-white/5">
        <input
          id="roomInput"
          class="bg-transparent border-none rounded text-xs px-3 focus:ring-0 text-on-surface placeholder:text-on-surface-variant/30 w-24 outline-none"
          placeholder="ROOM CODE"
          type="text"
        />
        <button id="joinBtn" class="bg-surface-container-high hover:bg-surface-bright text-on-surface px-3 py-1.5 rounded text-xs font-bold transition-colors">
          Join
        </button>
      </div>
      <div class="flex items-center gap-2">
        <a href="/profile" class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-highest/60 border border-white/5 hover:bg-surface-variant transition-colors" title="Meu perfil">
          <span class="material-symbols-outlined text-on-surface-variant text-xl">account_circle</span>
        </a>
        <button id="loginBtn" class="bg-primary text-on-primary px-5 py-2 rounded-lg font-bold tracking-wide transition-all active:scale-95 duration-150">
          Login
        </button>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="flex-1 flex flex-col items-center justify-center p-4 md:p-12">
    <div class="w-full max-w-[760px] flex flex-col gap-6">

      <!-- Status & Timers Bar -->
      <div class="flex flex-col sm:flex-row items-center justify-between bg-surface-container-low rounded-2xl p-5 border border-white/5 shadow-xl gap-4">
        <div class="flex items-center gap-4">
          <div class="bg-primary/10 p-3 rounded-xl border border-primary/20">
            <span class="material-symbols-outlined text-primary text-xl">hourglass_empty</span>
          </div>
          <div>
            <p class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold">Status</p>
            <p id="turnText" class="text-base font-bold text-on-surface">—</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="text-right">
            <p class="text-[9px] uppercase tracking-tighter text-on-surface-variant mb-1">Black</p>
            <div class="bg-surface-container-highest px-5 py-2.5 rounded-xl font-headline text-2xl font-bold text-tertiary border border-white/5 min-w-[100px] text-center">
              <span id="blackTimer">05:00</span>
            </div>
          </div>
          <div class="text-right">
            <p class="text-[9px] uppercase tracking-tighter text-secondary mb-1">White</p>
            <div class="bg-secondary px-5 py-2.5 rounded-xl font-headline text-2xl font-bold text-on-secondary shadow-xl shadow-secondary/20 border border-secondary/50 min-w-[100px] text-center">
              <span id="whiteTimer">05:00</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Chess Board -->
      <div class="w-full bg-surface-container-low p-3 rounded-xl shadow-[0_0_80px_rgba(0,0,0,0.5)] border border-white/5">
        <div id="board" class="w-full"></div>
      </div>

      <!-- Hidden elements used by JS (status, FEN, PGN, player info) -->
      <div class="hidden" aria-hidden="true">
        <div id="status"></div>
        <div id="statusDot"></div>
        <div id="turnDot"></div>
        <div id="fen"></div>
        <div id="pgn"></div>
        <div id="playerCard">
          <div id="pieceIcon"></div>
          <div id="playerName"></div>
          <div id="playerRoleEl"></div>
        </div>
      </div>

      <!-- Mobile room input (visible below board on small screens) -->
      <div class="flex sm:hidden bg-surface-container-highest/40 p-2 rounded-lg items-center gap-2 border border-white/5">
        <input
          id="roomInputMobile"
          class="bg-transparent border-none rounded text-xs px-3 focus:ring-0 text-on-surface placeholder:text-on-surface-variant/30 flex-1 outline-none"
          placeholder="ROOM CODE"
          type="text"
        />
        <button id="joinBtnMobile" class="bg-surface-container-high hover:bg-surface-bright text-on-surface px-3 py-1.5 rounded text-xs font-bold transition-colors">
          Join
        </button>
      </div>

      <!-- Match Actions -->
      <div class="grid grid-cols-2 gap-4">
        <button
          id="startBtn"
          disabled
          class="py-4 px-6 bg-surface-container-high hover:bg-surface-bright text-on-surface rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 border border-white/5 group disabled:opacity-30 disabled:cursor-not-allowed"
        >
          <span class="font-bold tracking-wide uppercase text-xs">Start</span>
          <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors text-sm">play_arrow</span>
        </button>
        <button
          id="resignBtn"
          disabled
          class="py-4 px-6 bg-surface-container-high hover:bg-surface-bright text-on-surface rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 border border-white/5 group disabled:opacity-30 disabled:cursor-not-allowed"
        >
          <span class="font-bold tracking-wide uppercase text-xs">Resign</span>
          <span class="material-symbols-outlined text-error/50 group-hover:text-error transition-colors text-sm">flag</span>
        </button>
      </div>

      <!-- Find New Match -->
      <div class="flex flex-col items-center gap-5 mt-2">
        <button
          id="matchmakingBtn"
          class="w-full max-w-md py-4 rounded-xl font-bold text-sm tracking-widest uppercase transition-all active:scale-95 flex items-center justify-center gap-3 shadow-xl"
        >
          <div id="mmSpinner" style="display:none" class="spinner-ring"></div>
          <span class="material-symbols-outlined text-lg">videogame_asset</span>
          <span id="mmBtnText">Find New Match</span>
        </button>
        <div class="flex justify-center gap-8 opacity-40 hover:opacity-100 transition-opacity">
          <button class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-sm">settings</span> Settings
          </button>
          <button class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest hover:text-error transition-colors">
            <span class="material-symbols-outlined text-sm">logout</span> Logout
          </button>
        </div>
      </div>

    </div>
  </main>

  <footer class="py-8 text-center opacity-30">
    <p class="text-[10px] font-bold tracking-[0.4em] uppercase">Est. 1886 • The Grandmaster Editorial</p>
  </footer>

  <!-- Pawn Promotion Modal -->
  <div class="promo-overlay" id="promoModal">
    <div class="promo-box">
      <div class="promo-title">Promote pawn to:</div>
      <div class="promo-options" id="promoOptions">
        <button class="promo-btn" data-piece="q">♛</button>
        <button class="promo-btn" data-piece="r">♜</button>
        <button class="promo-btn" data-piece="b">♝</button>
        <button class="promo-btn" data-piece="n">♞</button>
      </div>
    </div>
  </div>

  <!-- Libs -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"
          integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
          crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.js"></script>
  <script src="/public/scripts/indexScript.js"></script>
</body>
</html>
