<!DOCTYPE html>
<html class="dark" lang="pt-br">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>Perfil - The Grandmaster</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif:wght@400;600;700&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <style>
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  </style>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "background":              "#09151a",
            "surface":                 "#09151a",
            "surface-dim":             "#09151a",
            "surface-bright":          "#2f3b41",
            "surface-container-lowest":"#041015",
            "surface-container-low":   "#111d23",
            "surface-container":       "#152127",
            "surface-container-high":  "#202c32",
            "surface-container-highest":"#2a363d",
            "surface-variant":         "#2a363d",
            "on-background":           "#d7e4ec",
            "on-surface":              "#d7e4ec",
            "on-surface-variant":      "#d3c3c0",
            "outline":                 "#9c8d8b",
            "outline-variant":         "#504442",
            "primary":                 "#88d982",
            "on-primary":              "#003909",
            "primary-container":       "#003508",
            "primary-fixed":           "#a3f69c",
            "on-primary-container":    "#56a555",
            "secondary":               "#e9c176",
            "on-secondary":            "#412d00",
            "secondary-container":     "#604403",
            "tertiary":                "#cfc4c0",
            "tertiary-container":      "#322c29",
            "inverse-surface":         "#d7e4ec",
            "error":                   "#ffb4ab"
          },
          borderRadius: {
            "DEFAULT": "0.125rem",
            "lg":      "0.25rem",
            "xl":      "0.5rem",
            "full":    "0.75rem"
          },
          fontFamily: {
            "headline": ["Noto Serif", "serif"],
            "body":     ["Inter", "sans-serif"],
            "label":    ["Inter", "sans-serif"]
          }
        }
      }
    }
  </script>
</head>
<body class="bg-background text-on-background font-body min-h-screen flex flex-col">

  <!-- Header -->
  <header class="w-full flex justify-between items-center px-6 md:px-12 h-20 bg-surface-container-low/50 backdrop-blur-md border-b border-outline-variant/10 z-50">
    <a href="/" class="text-xl font-headline italic text-on-surface tracking-widest hover:text-primary transition-colors">
      The Grandmaster Editorial
    </a>
    <a href="/" class="flex items-center gap-2 text-on-surface-variant hover:text-on-surface transition-colors text-sm font-label">
      <span class="material-symbols-outlined text-base">arrow_back</span>
      Voltar ao jogo
    </a>
  </header>

  <main class="flex-1 flex items-center justify-center p-4 md:p-8">
    <div class="w-full max-w-lg">

      <!-- Avatar + nome -->
      <div class="flex flex-col items-center mb-8">
        <div class="w-20 h-20 rounded-full bg-primary-container border border-primary/20 flex items-center justify-center mb-4 shadow-lg shadow-primary/10">
          <span class="font-headline text-3xl text-primary select-none">
            {{ if .User.Name }}{{ slice .User.Name 0 1 }}{{ else }}?{{ end }}
          </span>
        </div>
        <h1 class="font-headline text-2xl text-on-surface font-semibold">{{ .User.Name }}</h1>
        <p class="text-on-surface-variant text-sm mt-1">Jogador</p>
      </div>

      <!-- Card de informações -->
      <div class="bg-surface-container-low rounded-xl border border-outline-variant/15 overflow-hidden shadow-[0_20px_40px_-15px_rgba(4,16,21,0.5)]">

        <div class="px-6 py-4 border-b border-outline-variant/10">
          <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">Informações da conta</p>
        </div>

        <!-- Nome -->
        <div class="flex items-center gap-4 px-6 py-5 border-b border-outline-variant/10">
          <div class="w-9 h-9 rounded-lg bg-surface-container-highest flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-on-surface-variant text-base">person</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[10px] uppercase tracking-widest text-on-surface-variant/60 mb-0.5">Nome de usuário</p>
            <p class="text-on-surface font-medium truncate">{{ .User.Name }}</p>
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-center gap-4 px-6 py-5 border-b border-outline-variant/10">
          <div class="w-9 h-9 rounded-lg bg-surface-container-highest flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-on-surface-variant text-base">mail</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[10px] uppercase tracking-widest text-on-surface-variant/60 mb-0.5">E-mail</p>
            <p class="text-on-surface font-medium truncate">{{ .User.Email }}</p>
          </div>
        </div>

        <!-- ID -->
        <div class="flex items-center gap-4 px-6 py-5">
          <div class="w-9 h-9 rounded-lg bg-surface-container-highest flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-on-surface-variant text-base">tag</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[10px] uppercase tracking-widest text-on-surface-variant/60 mb-0.5">ID do jogador</p>
            <p class="text-on-surface-variant font-mono text-sm">#{{ .User.ID }}</p>
          </div>
        </div>

      </div>

      <!-- Ações -->
      <div class="mt-6 flex flex-col gap-3">
        <a href="/"
           class="w-full bg-primary text-on-primary rounded-lg py-3 font-label font-medium flex items-center justify-center gap-2 hover:bg-primary-fixed transition-colors duration-200 shadow-lg shadow-primary/10">
          <span class="material-symbols-outlined text-sm">chess</span>
          Jogar agora
        </a>
        <button
          onclick="fetch('/logout',{method:'POST',credentials:'include'}).then(()=>window.location.href='/login')"
          class="w-full bg-surface-container-high text-on-surface border border-outline-variant/15 rounded-lg py-3 font-label font-medium flex items-center justify-center gap-2 hover:bg-surface-variant transition-colors duration-200">
          <span class="material-symbols-outlined text-sm">logout</span>
          Sair
        </button>
      </div>

    </div>
  </main>

  <footer class="py-6 text-center opacity-20">
    <p class="text-[10px] font-bold tracking-[0.4em] uppercase">Est. 1886 • The Grandmaster Editorial</p>
  </footer>

</body>
</html>
