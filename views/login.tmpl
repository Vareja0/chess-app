<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login | Minha Aplicação</title>
  <link rel="stylesheet" href="../public/assets/loginStyle.css">
</head>
<body>

  <div class="login-container">
    <h1>Entrar
      {{ if .Success }} — {{ .Success }}{{ end }}
      
    </h1>

    <form id="loginForm">
      <div class="form-group">
        <label for="email">E-mail</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          placeholder="seu@email.com" 
          required 
          autocomplete="email"
        >
      </div>

      <div class="form-group">
        <label for="password">Senha</label>
        <input 
          type="password" 
          id="password" 
          name="password" 
          placeholder="••••••••" 
          required 
          autocomplete="current-password"
        >
      </div>

      <button type="submit" class="btn-login" id="btnSubmit">Entrar</button>

      <div class="error-message" id="errorMsg"></div>
      <div class="success-message" id="successMsg"></div>
    </form>

    <div class="divider">não tem conta?</div>
    <button class="btn-signup" onclick="window.location.href='/signup'">Criar conta</button>
  </div>
<script src="../public/scripts/loginScript.js"></script>
</body>
</html>

